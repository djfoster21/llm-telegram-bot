# Copy to .env and fill in.
# All numeric values shown below are the defaults the code uses if the env
# var is unset, so you only need to set the ones you want to override.

# =============================================================================
# Required: Telegram + access control
# =============================================================================

# Telegram bot token from @BotFather. Looks like "1234567890:AAEh...".
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the bot in DMs.
# To find your ID: message @userinfobot on Telegram.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Optional: Giphy API key for the send_meme tool. Free tier (100 req/hour,
# 1000/day) — register at https://developers.giphy.com. If unset, the
# send_meme tool returns an error and the model falls back to text.
GIPHY_API_KEY=

# Optional: comma-separated CHAT IDs (groups) where anyone can use the bot.
# Add the bot to the group, then send /status@<botname> to see the chat ID
# (group IDs are negative numbers).
# Example: ALLOWED_CHAT_IDS=-1001234567890,-1009876543210
# Leave empty if you don't use groups.
ALLOWED_CHAT_IDS=

# =============================================================================
# Model
# =============================================================================
# Swap to any GGUF: change both URL and FILE. On startup, model-init downloads
# the file if it isn't already present in ./models.
# Reasoning models (Qwen3-Thinking, QwQ, R1-distills) are supported: the bot
# strips <think>...</think> blocks from both streamed output and history so
# the model's scratchpad never reaches the chat or feeds back into context.
# Example: Qwen3-4B-Instruct-2507 Q4_K_M (faster, smaller machines)
#   MODEL_URL=https://huggingface.co/bartowski/Qwen_Qwen3-4B-Instruct-2507-GGUF/resolve/main/Qwen_Qwen3-4B-Instruct-2507-Q4_K_M.gguf
#   MODEL_FILE=Qwen_Qwen3-4B-Instruct-2507-Q4_K_M.gguf
# Example: Qwen3-30B-A3B-Thinking-2507 Q4_K_M (~18 GB, MoE — fast for its size)
#   MODEL_URL=https://huggingface.co/bartowski/Qwen_Qwen3-30B-A3B-Thinking-2507-GGUF/resolve/main/Qwen_Qwen3-30B-A3B-Thinking-2507-Q4_K_M.gguf
#   MODEL_FILE=Qwen_Qwen3-30B-A3B-Thinking-2507-Q4_K_M.gguf
MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-7B-Instruct-GGUF/resolve/main/Qwen2.5-7B-Instruct-Q3_K_M.gguf
MODEL_FILE=Qwen2.5-7B-Instruct-Q3_K_M.gguf

# =============================================================================
# llama.cpp tuning (consumed by the llama-server container, not the bot)
# =============================================================================
# LLAMA_IMAGE: which llama.cpp server image to run. Defaults to the CUDA build
#   (ghcr.io/ggml-org/llama.cpp:server-cuda), which needs nvidia-container-
#   runtime on the host. To run on CPU only, either set this to the CPU build
#   below AND start the stack with the CPU override file:
#     docker compose -f docker-compose.yml -f docker-compose.cpu.yml up -d --build
#   The override is required because it also removes the nvidia GPU
#   reservation from the base compose file (which would otherwise refuse to
#   start on a host without an NVIDIA runtime).
#   Other variants exist: server-rocm (AMD), server-vulkan, server-musa.
# LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
# LLAMA_CTX: context window in tokens. Larger = more memory + slower
#   per-token. Capped at the model's training context. Default 4096.
LLAMA_CTX=4096
# LLAMA_THREADS: CPU threads for layers that don't fit on GPU. Match physical
#   cores. This box has 4. Default 4.
LLAMA_THREADS=4
# LLAMA_NGL: layers to offload to GPU. NVIDIA 940M (2 GB VRAM) fits ~9 layers
#   of Qwen2.5-7B-Q3_K_M. Set to 0 for CPU-only. Too high -> CUDA OOM at boot.
LLAMA_NGL=9

# =============================================================================
# LLM sampling (bot -> llama-server request body)
# =============================================================================
# Qwen 2.5 and Qwen 3 share the same official sampling recipe.

# MAX_RESPONSE_TOKENS: hard cap on tokens the model can generate per turn.
#   800 ≈ 3000 chars, well under Telegram's 4096-char message limit. Increase
#   if you want longer replies (and your context budget allows). Default 800.
MAX_RESPONSE_TOKENS=800

# LLM_TEMPERATURE: higher = more variety, lower = more deterministic.
#   Qwen recipe is 0.7. Drop to 0.5 if you see frequent language drift or
#   off-topic responses. Default 0.7.
LLM_TEMPERATURE=0.7

# LLM_TOP_P: nucleus sampling cutoff. Qwen recipe is 0.8.
LLM_TOP_P=0.8

# LLM_TOP_K: top-K sampling cutoff. Qwen recipe is 20.
LLM_TOP_K=20

# LLM_MIN_P: minimum probability mass for a token to be considered.
#   Qwen 3 recommends explicit 0. Default 0.
LLM_MIN_P=0

# LLM_REPEAT_PENALTY: llama.cpp extension (not OpenAI). 1.0 disables it.
#   Higher values can suppress tool-call tokens, so keep at 1.0 unless you
#   see actual repetition loops. Default 1.0.
LLM_REPEAT_PENALTY=1.0

# =============================================================================
# Conversation history & context
# =============================================================================

# HISTORY_TOKEN_BUDGET: how many tokens of past conversation to send with
#   every LLM call. The bot archives every message; this trims oldest-first
#   to fit. Default 1200. Lower it on cache miss to re-evaluate less; raise
#   it if the bot keeps forgetting recent context.
HISTORY_TOKEN_BUDGET=1200

# MAX_STORED_MESSAGES: absolute cap on per-chat rows kept in SQLite so disk
#   doesn't grow forever. Older messages stay in the FTS5 recall index even
#   after they fall off the live history. Default 300.
MAX_STORED_MESSAGES=300

# CONTEXT_WARN_THRESHOLD: estimated prompt token count at which the bot
#   logs a warning and posts a one-shot Telegram message asking for /reset.
#   Set conservatively below llama-server's context window (LLAMA_CTX).
#   Default 3500 (out of 4096).
CONTEXT_WARN_THRESHOLD=3500

# CONTEXT_WARN_COOLDOWN_MIN: per-chat rate limit on the warning message
#   above, in minutes. Default 60.
CONTEXT_WARN_COOLDOWN_MIN=60

# =============================================================================
# Streaming & UX
# =============================================================================

# STREAM_INTERVAL_MS: minimum gap between text-message edits while the model
#   is streaming, in milliseconds. Lower = snappier preview, but Telegram
#   rate-limits group edits hard — going below ~2000 ms triggers 429s and
#   ultimately makes the final reply look truncated. Default 2500.
STREAM_INTERVAL_MS=2500

# =============================================================================
# Group behavior (only effective in chats listed in ALLOWED_CHAT_IDS)
# =============================================================================

# REACTION_PROBABILITY: chance (0.0–1.0) that the bot puts an emoji reaction
#   on a message whose text matches one of its regex patterns. Reactions are
#   pattern-based — no LLM call involved. Default 0.4.
#   Examples: 0.2 = quieter, 0.8 = very reactive.
REACTION_PROBABILITY=0.4

# SPONTANEOUS_MIN / SPONTANEOUS_MAX: how often the bot chimes in unprompted.
#   Every N user messages (chosen uniformly from [MIN, MAX]), the bot
#   generates an unsolicited comment. Defaults: 1 / 15.
#   Examples:
#     SPONTANEOUS_MIN=5, SPONTANEOUS_MAX=20  -> chimes every 5-20 msgs (calmer)
#     SPONTANEOUS_MIN=1, SPONTANEOUS_MAX=3   -> very chatty
SPONTANEOUS_MIN=1
SPONTANEOUS_MAX=15

# =============================================================================
# Auto-summarization
# =============================================================================
# When a chat grows past AUTO_SUMMARY_AT_MESSAGES, the oldest portion is
# compressed into a single "[CONTEXTO ANTERIOR]" message so the bot keeps
# long-term context without blowing the token budget.

# AUTO_SUMMARY_AT_MESSAGES: trigger threshold (stored messages). Default 60.
AUTO_SUMMARY_AT_MESSAGES=60

# AUTO_SUMMARY_KEEP_RECENT: how many recent messages to keep verbatim after
#   summarization. Default 30. Must be smaller than AUTO_SUMMARY_AT_MESSAGES.
AUTO_SUMMARY_KEEP_RECENT=30

# AUTO_SUMMARY_COOLDOWN_MIN: minimum gap between summarization runs per chat,
#   in minutes. Prevents thrashing. Default 30.
AUTO_SUMMARY_COOLDOWN_MIN=30
