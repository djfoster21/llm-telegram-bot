# Copy to .env and fill in.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot in DMs.
# To find your ID: message @userinfobot on Telegram.
ALLOWED_USER_IDS=

# Optional: comma-separated Telegram CHAT IDs (groups) where anyone can use the bot.
# Add the bot to the group, then send /status@<botname> to see the chat ID (negative number).
# Leave empty if you don't use groups.
ALLOWED_CHAT_IDS=

# Model — defaults below are Qwen 2.5 3B Instruct Q4_K_M (ungated, ~2 GB).
# Swap to any GGUF: change both URL and FILE.
MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-3B-Instruct-GGUF/resolve/main/Qwen2.5-3B-Instruct-Q4_K_M.gguf
MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf

# llama.cpp tuning.
# LLAMA_CTX: context window in tokens. Larger = more memory + slower per-token.
# LLAMA_THREADS: match physical cores; this CPU has 4 (2c/4t).
# LLAMA_NGL: layers offloaded to GPU. 24/36 fits Qwen 2.5 3B Q4 in 2 GB VRAM.
#   Set to 0 for CPU-only. Raise toward 36 if you have more VRAM headroom.
LLAMA_CTX=4096
LLAMA_THREADS=4
LLAMA_NGL=24

# Token budget for chat history forwarded to the model on each turn.
# We archive every message in allowed chats; this caps how much of that
# history is included in each LLM call. Trims oldest-first.
HISTORY_TOKEN_BUDGET=2500
